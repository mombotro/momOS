pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--d&d dice roller

dices={
	{"d4",4,1,-1,true},
	{"d6",6,5,0,true},
	{"d8",8,9,-1,true},
	{"d10",10,64,1,true},
	{"d12",12,68,3,false},
	{"d20",20,72,5,false},
	{"d100",100,64,3,false}
}

dice=2
toroll=1
maxroll=60
res={}

margin=5

function _init()
	
end

function _update()
	if(btnp(➡️))dice+=1
	if(btnp(⬅️))dice-=1 
	if(btnp(⬆️))toroll=min(toroll+1,maxroll)
	if(btnp(⬇️))toroll=max(toroll-1,1)
	
	if dice<1 then
		dice=#dices
	elseif dice>#dices then
		dice=1
	end
	
	if(btnp(❎))rolldice()
end

function _draw()
	cls()
	
	draw_dice(margin,margin)
	
	print("current dice:"..dices[dice][1],margin*2+32,margin+2,6)
	print("dices to roll:"..toroll,margin*2+32,margin*2+3,6)
	if(#res>0) print("total:"..gettotal(),margin*2+32,margin*4+3,6)
	
	for y=1,6 do
		for x=1,10 do
			local index=(y-1)*10+x
			if(index>#res) goto finish
			local bcol="\#1"
			local col=6
			if(res[index]==1)bcol="\#8"
			if(res[index]==20)bcol="\#3"col=9
			print(bcol..res[index],margin*x+x*6,32+y*7+1*y,col)
		end
	end
	::finish::
	
	draw_inst()
end

function draw_dice(x,y)
	spr(dices[dice][3],x,y,4,4)
	local txt=tostr(dices[dice][2])
	if dices[dice][5] then
		print("\^w\^t"..txt,x+17-#txt*4,y+10+dices[dice][4],9)
	else
		print(txt,x+16-#txt*2,y+10+dices[dice][4],9)
	end
end

function draw_inst()
	local y=97
	rectfill(0,y,120,120,8)
	print("⬅️➡️ to select dice",margin,y+1,15)
	print("⬆️⬇️ to select how many",margin,y+2+7,15)
	print("❎ to roll",margin,y+3+14,15)
end

function rolldice()
	res={}
	local max=dices[dice][2]
	for i=1,toroll do
		add(res,ceil(rnd(max)))
	end
	
	if(toroll>1)sort()
end

function gettotal()
	local sum=0
	for i in all(res) do
		sum+=i
	end
	
	return sum
end

function sort()
	local sorted=false
	local index=1
	for i=1,#res do
		index=1
		sorted=false
		while not sorted do
			if(res[index]>res[index+1])swap(res,index,index+1)
			index+=1
			if(index>#res-1)sorted=true
		end
	end
end

function swap(tbl,a,b)
	local temp=tbl[a]
	tbl[a]=tbl[b]
	tbl[b]=temp
end
__gfx__
